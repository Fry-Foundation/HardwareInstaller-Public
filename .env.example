# Environment variables for FryNetworks Hardware Installer Build Script
# Copy this file to .env and fill in the actual values

# 1Password references for retrieving secrets
OP_BEARER_TOKEN_REF=op://VPS/Hardware_API/API_BEARER_TOKEN

# GUI GitHub repository (for installer GUI)
OP_GUI_GITHUB_REPO_REF=op://VSCode/hardware_exe/Github_repo_test
OP_GUI_GITHUB_TOKEN_REF=op://VSCode/hardware_exe/Github_token

# PoC GitHub repository (for miner service executables)
OP_POC_GITHUB_REPO_REF=op://VSCode/hardware_exe/Github_repo_poc
OP_POC_GITHUB_TOKEN_REF=op://VSCode/hardware_exe/Github_token_poc

# External API configuration
EXTERNAL_API_BASE_URL=https://hardwareapi.frynetworks.com

# Partner integration secrets (retrieved during build; set to the 1Password item IDs)
# Public build: only Mysterium (credentials handled at runtime)
