{
  "BM": {
    "name": "Bandwidth Miner",
    "description": "Network bandwidth monitoring and mining",
    "group": "Bandwidth",
    "exclusive": null,
    "system_packages": {
      "linux": [
        "python3-psutil",
        "python3-requests", 
        "net-tools",
        "iperf3"
      ],
      "windows": [
        "python3",
        "pip"
      ]
    },
    "python_packages": [
      "psutil>=5.8.0",
      "requests>=2.25.0",
      "netifaces>=0.10.0"
    ],
    "services": {
      "linux": ["network-manager", "systemd-networkd"],
      "windows": []
    },
    "permissions": [
      "network_monitoring",
      "interface_access"
    ],
    "hardware": [
      "network_interface",
      "ethernet_adapter"
    ],
    "config_files": [
      "network_interfaces.conf",
      "bandwidth_thresholds.conf"
    ],
    "optional": {
      "system_packages": {
        "linux": ["speedtest-cli", "nmap", "tcpdump"],
        "windows": ["wireshark", "nmap"]
      },
      "python_packages": ["speedtest-cli>=2.1.0"],
      "description": "Enhanced network analysis and testing tools"
    },
    "verification": {
      "commands": ["ip link show", "ping -c 1 8.8.8.8"],
      "python_imports": ["psutil", "requests"],
      "hardware_check": "network_interface_detection"
    }
  },
  
  "IDM": {
